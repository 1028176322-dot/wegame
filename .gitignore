# 临时与缓存（方案 §4.10、§16）
.scratch/
.cache/
outputs/logs/
*.tmp
*.log
*.bak

# 系统
.DS_Store
Thumbs.db

# 发布产物（通常不直接提交，方案 §4.3）
dist/
build/
releases/

# 依赖（引擎/技术栈选型后按需补充）
node_modules/

# Python 缓存（运行校验器生成，非源码）
__pycache__/
*.pyc

# 注意：.workbuddy/ 为项目治理运行目录（memory/skills/协调文件），
# 由 Decision Owner 裁定须纳入版本控制（见 AUTHORITY_INDEX 冻结锁注释），故不忽略。
